[Unit]
Description=Polymarket Paper Trading Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/polymarket-bot
ExecStart=/root/polymarket-bot/venv/bin/python bot_paper.py
Restart=always
RestartSec=10
StandardOutput=append:/root/polymarket-bot/paper_trading.log
StandardError=append:/root/polymarket-bot/paper_trading.log

[Install]
WantedBy=multi-user.target
